# TeamOS environment configuration.
# Copy to apps/web/.env.local for local development.
# NEVER commit real secrets. Frontend must not contain any of these values.

# --- Workspace identity ---
# Comma-separated list of allowed Google Workspace email domains.
TEAMOS_ALLOWED_DOMAINS=example.com

# --- Dev login (local only) ---
# When true, the /login page exposes seeded demo users so the app runs
# without a real Google OAuth project. Disable in any shared deployment.
TEAMOS_DEV_LOGIN=true

# --- Google OAuth (server-side only) ---
# Required only when TEAMOS_DEV_LOGIN=false and real Google sign-in is wired.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Gemini API (server-side only, advisory AI) ---
# When empty, TeamOS uses the deterministic offline summarizer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Data backend selection ---
# memory = in-memory seeded repositories (default, runnable now)
# sheets = Google Sheets via Apps Script API (see apps/appsscript)
TEAMOS_DATA_BACKEND=memory

# Apps Script web app URL when TEAMOS_DATA_BACKEND=sheets
TEAMOS_APPS_SCRIPT_URL=
