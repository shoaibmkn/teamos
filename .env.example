# TeamOS environment configuration.
# Local dev: copy to apps/web/.env.local. Production: set these in Vercel.
# NEVER commit real secrets. The frontend never receives any of these values.
# Full deploy guide: see DEPLOY.md.

# --- Data backend ---
# memory = in-memory seeded demo (default, no setup needed)
# sheets = Google Sheets via service account (production)
TEAMOS_DATA_BACKEND=memory

# --- Workspace identity ---
# Comma-separated allowed Google Workspace email domains.
TEAMOS_ALLOWED_DOMAINS=example.com

# --- Dev login (local only) ---
# true exposes seeded demo accounts on /login. Set false in production.
TEAMOS_DEV_LOGIN=true

# --- Google Sheets backend (TEAMOS_DATA_BACKEND=sheets) ---
TEAMOS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key from the service-account JSON, including the \n sequences.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Seeded as the first Admin on /api/admin/setup.
TEAMOS_ADMIN_EMAIL=
# Random string; required once to call /api/admin/setup.
TEAMOS_SETUP_TOKEN=

# --- Google OAuth (Workspace sign-in) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public base URL of the deployment (used to build the OAuth redirect URI).
NEXTAUTH_URL=http://localhost:3000

# --- Gemini API (server-side only, advisory AI) ---
# Empty = deterministic offline summarizer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
